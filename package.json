{
  "name": "fictionflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "FictionFlow — AI roleplay platform (backend + static frontend)",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node scripts/run.mjs",
    "dev": "node scripts/run.mjs --dev",
    "postinstall": "npm install --prefix backend && npm install --prefix frontend",
    "build:css": "npm run build:css --prefix frontend",
    "watch:css": "npm run watch:css --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "backend": "npm start --prefix backend",
    "backend:dev": "npm run dev --prefix backend"
  },
  "workspaces": ["backend", "frontend"]
}
