+  const cleaned = [];
+  for (const line of trimmed.split('\n')) {
+    const lt = line.trim();
+    if (lt.startsWith('{') && !lt.includes('}')) continue;
+    cleaned.push(line);
+  }
+  return cleaned.join('\n');
