   if (pack === 'en-US') {
     return g === 'female' ? 'en-US-JennyNeural' : 'en-US-GuyNeural';
   }
   // Default: id-ID.
   return g === 'female' ? 'id-ID-GadisNeural' : 'id-ID-ArdiNeural';
 }
 
