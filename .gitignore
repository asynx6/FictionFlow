# ============================================================
# FictionFlow .gitignore
# Tujuan: prevent credentials, generated artifacts, dan data
# privile (SQLite, logs) ikut ter-commit/push ke public GitHub.
# ============================================================

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- Backend runtime artifacts ---
# SQLite database: privasi user (story + messages + memory).
# Ignore SELURUH isi folder data/, termasuk WAL/SHM/journal dan
# backup apa pun yang mungkin muncul nanti.
data/

# Backend logs dan error dumps (auto-created by run.ps1 + npm start).
# Lokasi: backend/errs.txt, backend/logs.txt
backend/errs.txt
backend/logs.txt
errs.txt
logs.txt

# --- Secrets / local config ---
.env
.env.local
.env.*.local

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Build artifacts ---
dist/
build/
coverage/
*.tsbuildinfo

# --- Frontend (Tailwind compiled output is large + auto-built) ---
frontend/public/css/tailwind.output.css
frontend/dist/

# --- Local-only skills / agent customizations ---
# Tidak disimpan ke repo karena setiap developer punya preferensi sendiri.
GEMINI.md
AGENTS.md
.claude/
.openclaude/
skills/

# --- Scratch / experiment files ---
scratch/
# --- Audit / agent scratch (not part of codebase) ---
.superpowers/
scratch/
