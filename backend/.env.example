# FictionFlow — backend/.env example.
#
# Provider config (.env-only — there is no UI picker, no per-story override,
# no fallback). Backend refuses to start if any of the three keys below is
# empty or still a placeholder.
#
# Pick ONE provider and fill THE THREE required fields:

# --- 9Router local (free, port 20128) ---
MODEL_PROVIDER_BASE_URL=http://localhost:20128/v1
MODEL_PROVIDER_API_KEY=anything
DEFAULT_MODEL_ID=im/DeepSeek-V4-Flash

# --- OpenRouter (cloud, paid) ---
# MODEL_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
# MODEL_PROVIDER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# DEFAULT_MODEL_ID=openrouter/auto
#
# ─────────────────────────────────────────────────────────────────────
# Fallback chain (optional, up to 11 slots total — slot 0 + DEFAULT_MODEL_ID_1.._10)
# ─────────────────────────────────────────────────────────────────────
# If the primary model fails (provider error / model not found / quota), the
# backend automatically retries with the next non-empty slot in order. Empty
# slots are skipped silently — set ONLY the ones you want available.
#
# Examples:
#   DEFAULT_MODEL_ID_1=im/another-model
#   DEFAULT_MODEL_ID_2=im/backup-cheap-model
#   DEFAULT_MODEL_ID_5=im/deepseek-secondary

# ---- Server ----
PORT=3000
NODE_ENV=production

# ---- Database ----
DB_PATH=./data/fictionflow.sqlite

# ---- Memory ----
# Number of recent (user + AI) message pairs injected into the AI context.
# Allowed range: 3–5. Default 4.
DEFAULT_SHORT_TERM_WINDOW=4
